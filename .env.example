# ICRS configuration — copy to `.env` and fill in real values.
# NEVER commit a real .env file. Secrets are read from the environment only.

# ===== LLM provider API keys =====
# Groq (free tier, OpenAI-compatible) — used for JD decomposition + contextual reranking.
# Create a key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Google Gemini (free tier) — used for explanation generation.
# Create a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# OpenRouter (free/paid models) — alternative for ranking to bypass Groq rate limits.
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ===== LLM model selection (overridable) =====
ICRS_GROQ_MODEL=llama-3.3-70b-versatile
ICRS_OPENROUTER_MODEL=google/gemini-2.5-flash:free
ICRS_GEMINI_MODEL=gemini-2.5-flash

# ===== Embedding provider (local, free) =====
# Default is a local open-source model run via sentence-transformers (CPU-capable).
ICRS_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
ICRS_EMBEDDING_DIM=1024
ICRS_EMBEDDING_DEVICE=cpu
# Keeps downloaded Hugging Face / sentence-transformers model files inside this repo.
ICRS_MODEL_CACHE_DIR=.cache/huggingface

# ===== Pipeline limits =====
# Token limit above which a profile is chunked before embedding.
ICRS_MAX_INPUT_TOKENS=512
# Reranking bound K (must be within 1..50).
ICRS_RERANK_K=10
# Number of top-ranked candidates to generate full LLM explanations for.
ICRS_EXPLAIN_TOP_N=5
# Candidate semantic enrichment mode:
#   local = no per-resume LLM calls; fastest and recommended for free-tier bulk runs.
#   llm   = original per-resume LLM semantic enrichment; use only for small pools.
ICRS_ENRICHMENT_MODE=local

# ===== Persistence =====
ICRS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/icrs
ICRS_QDRANT_URL=http://localhost:6333

# ===== Redis Caching =====
ICRS_REDIS_URL=redis://localhost:6379/0
ICRS_REDIS_TTL=86400

# ===== Determinism =====
# Fixed seed used by deterministic stages and the Hypothesis test profile.
ICRS_RANDOM_SEED=1729
